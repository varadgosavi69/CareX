# ─────────────────────────────────────────────────────────────
# CareX Backend — Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/carex

# CORS — the origin of the frontend SPA that is allowed to call this API
CLIENT_ORIGIN=http://localhost:5173

# JWT secrets (use long, random strings — e.g. `openssl rand -hex 32`)
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string

# JWT lifetimes (zeit/ms format, e.g. 15m, 7d)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Admin seed — used once by `npm run seed:admin` to create the admin account
ADMIN_EMAIL=admin@carex.com
ADMIN_PASSWORD=change_me_to_a_strong_password

# Cloudinary — medical report file uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay — consultation fee payments (test keys from the Razorpay dashboard)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
