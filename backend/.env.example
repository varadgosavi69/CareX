# ─────────────────────────────────────────────────────────────
# CareX Backend — Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/carex

# CORS — the origin of the frontend SPA that is allowed to call this API
CLIENT_ORIGIN=http://localhost:5173

# JWT secrets (use long, random strings — e.g. `openssl rand -hex 32`)
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string

# JWT lifetimes (zeit/ms format, e.g. 15m, 7d)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
