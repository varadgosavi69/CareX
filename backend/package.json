{
  "name": "carex-backend",
  "version": "0.1.0",
  "description": "CareX healthcare appointment platform — REST API (Node.js + Express + MongoDB).",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules MONGOMS_VERSION=7.0.14 MONGOMS_MD5_CHECK=0 jest --runInBand",
    "seed:admin": "node src/seed/admin.seed.js",
    "seed:doctors": "node src/seed/doctors.seed.js",
    "lint": "echo \"No linter configured yet (placeholder)\" && exit 0"
  },
  "keywords": [
    "carex",
    "healthcare",
    "express",
    "mongodb",
    "rest-api"
  ],
  "license": "MIT",
  "config": {
    "mongodbMemoryServer": {
      "version": "7.0.14"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "razorpay": "^2.9.6",
    "winston": "^3.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
